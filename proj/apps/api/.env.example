# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/esocial_qa
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth — gere valores seguros antes de produção ────────────────────────────
# openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_MIN_32_CHARS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# openssl rand -hex 16
API_KEY_SALT=SUBSTITUA_POR_OUTRO_VALOR_ALEATORIO

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── Observabilidade ───────────────────────────────────────────────────────────
SENTRY_DSN=
