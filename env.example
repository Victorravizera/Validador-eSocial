# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development           # development | production | test
LOG_LEVEL=info                 # trace | debug | info | warn | error

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/esocial_qa
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Cache / Queue (Redis) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Em produção com autenticação: redis://:PASSWORD@HOST:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANTE: Gere valores seguros antes de ir para produção:
#   openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_DE_64_CHARS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Salt para hashing de API Keys — diferente do JWT_SECRET
API_KEY_SALT=SUBSTITUA_POR_OUTRO_VALOR_ALEATORIO

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100             # requests por janela
RATE_LIMIT_WINDOW_MS=60000    # 1 minuto

# ─── Cors ──────────────────────────────────────────────────────────────────────
# Separe múltiplas origens por vírgula
CORS_ORIGINS=http://localhost:3001

# ─── Observabilidade ───────────────────────────────────────────────────────────
SENTRY_DSN=                    # Deixe vazio para desabilitar
