{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "../../shared/**/*",
    "../../config/**/*",
    "../../rules/**/*"
  ],
  "exclude": ["node_modules", "dist", "test/**/*"]
}